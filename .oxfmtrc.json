{
  "$schema": "./node_modules/oxfmt/configuration_schema.json",
  "printWidth": 100,
  "singleQuote": true,
  "semi": false,
  "trailingComma": "all",
  "sortImports": {
    "partitionByNewline": true,
    "newlinesBetween": false
  },
  "sortTailwindcss": true,
  "ignorePatterns": ["src/paraglide/**"]
}
